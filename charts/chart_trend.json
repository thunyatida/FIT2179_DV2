{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Cumulative threatened species listings in Australia since 2000",
  "width": 520,
  "height": 260,
  "data": {"url": "data/listings_trend.json"},
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": {"color": "#e67e22", "strokeWidth": 2.5},
        "color": {
          "x1": 1, "y1": 1, "x2": 1, "y2": 0,
          "gradient": "linear",
          "stops": [
            {"offset": 0, "color": "rgba(230,126,34,0)"},
            {"offset": 1, "color": "rgba(230,126,34,0.3)"}
          ]
        }
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelFont": "Crimson Pro",
            "labelFontSize": 12,
            "labelAngle": -45
          }
        },
        "y": {
          "field": "cumulative",
          "type": "quantitative",
          "axis": {
            "title": "Cumulative Species Listed",
            "titleFont": "Crimson Pro",
            "labelFont": "Crimson Pro",
            "titleFontSize": 13,
            "labelFontSize": 12,
            "grid": true,
            "gridColor": "#333355",
            "gridOpacity": 0.4
          }
        },
        "tooltip": [
          {"field": "year", "type": "ordinal", "title": "Year"},
          {"field": "cumulative", "type": "quantitative", "title": "Total Listed"},
          {"field": "newly_listed", "type": "quantitative", "title": "New Listings"}
        ]
      }
    },
    {
      "mark": {
        "type": "rule",
        "color": "#c0392b",
        "strokeWidth": 1.5,
        "strokeDash": [4, 4]
      },
      "encoding": {
        "x": {"datum": "2019"},
        "color": {"value": "#c0392b"}
      }
    },
    {
      "mark": {
        "type": "text",
        "text": "Bushfire crisis",
        "color": "#c0392b",
        "fontSize": 11,
        "fontFamily": "Crimson Pro",
        "dx": 48,
        "dy": -80
      },
      "encoding": {
        "x": {"datum": "2019"}
      }
    }
  ],
  "config": {
    "background": "transparent",
    "view": {"stroke": null},
    "axis": {"domainColor": "#555577", "tickColor": "#555577"}
  }
}
